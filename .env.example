# Variables de entorno para la API de Películas con Prisma ORM
# Copia este archivo a .env y actualiza los valores

# URL de la base de datos PostgreSQL
DATABASE_URL="postgresql://tu_usuario:tu_password@localhost:5432/peliculas_db?schema=public"

# Secreto para JWT tokens (genera uno seguro)
JWT_SECRET="tu_secreto_super_seguro_aqui"

# Expiración del token JWT (opcional, por defecto 24h)
JWT_EXPIRES_IN="24h"

# Entorno de ejecución
NODE_ENV="development"

# Puerto del servidor (opcional, por defecto 3000)
PORT=3000
